OPENROUTER_API_KEY=sk-or-v1-your-key-here
MONGODB_URI=mongodb://localhost:27017
WEBFURL_COMPRESSION_MODEL=openai/gpt-oss-120b
WEBFURL_AGENT_MODEL=anthropic/claude-sonnet-4.6
WEBFURL_VISION_MODEL=google/gemini-2.5-flash
WEBFURL_TOKEN_BUDGET=5000
WEBFURL_MAX_BUDGET=128000
# Optional: path to Chrome/Chromium binary (auto-detected if not set)
# Linux:  CHROME_PATH=/usr/bin/google-chrome-stable
# Mac:    CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Optional: set to 1 for headless mode (default: visible browser)
# WEBFURL_HEADLESS=1
